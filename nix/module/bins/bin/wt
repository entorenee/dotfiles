#!/usr/bin/env bash
set -euo pipefail

# wt - git worktree manager using the sibling worktree pattern
#
# Sibling pattern: parent directory is a container, each worktree is a sibling.
#   project/
#     develop/      <- primary worktree (default branch)
#     feat-foo/     <- feature worktree
#     feat-bar/     <- feature worktree

open_tmux_window() {
  local name="$1" path="$2"
  if [ -n "${TMUX:-}" ]; then
    tmux new-window -n "$name" -c "$path" \; \
      send-keys "claude" Enter \; \
      split-window -h -c "$path"
  fi
}

ensure_git_repo() {
  if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    echo "error: not inside a git repository" >&2
    exit 1
  fi
}

ensure_gh_auth() {
  if ! gh auth status &>/dev/null; then
    echo "error: gh is not authenticated — run 'gh auth login'" >&2
    exit 1
  fi
}

project_root() {
  local main_wt
  main_wt=$(git worktree list --porcelain | head -1 | sed 's/^worktree //')
  dirname "$main_wt"
}

detect_base_branch() {
  for branch in develop main master; do
    if git show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null ||
       git show-ref --verify --quiet "refs/remotes/origin/$branch" 2>/dev/null; then
      echo "$branch"
      return
    fi
  done
  echo "error: could not detect base branch (tried develop, main, master)" >&2
  exit 1
}

cmd_help() {
  cat <<'EOF'
wt - git worktree manager (sibling pattern)

Usage: wt <command> [args]

Commands:
  add <name> [base]    Create a sibling worktree with branch <name> based on <base>
                        Base auto-detected: develop -> main -> master
  rm <name> [--force]  Remove a worktree and its local branch
                        Warns if unpushed commits exist (use --force to override)
  ls [--detail]        List worktrees (--detail adds commit info and PR status)
  pr <number> [name]   Create a worktree from a GitHub PR
  clean                Remove worktrees whose PRs have been merged
  help                 Show this help message
EOF
}

cmd_add() {
  local name="${1:?usage: wt add <name> [base]}"
  local base="${2:-}"
  local root

  root=$(project_root)

  if [ -d "$root/$name" ]; then
    echo "error: worktree '$root/$name' already exists" >&2
    exit 1
  fi

  if [ -z "$base" ]; then
    base=$(detect_base_branch)
  fi

  echo "fetching origin..."
  git fetch origin

  local base_ref
  if git show-ref --verify --quiet "refs/heads/$base"; then
    base_ref="$base"
  else
    base_ref="origin/$base"
  fi

  echo "creating worktree at ../$name (branch $name from $base_ref)"
  git worktree add "$root/$name" -b "$name" "$base_ref"
  echo "done."
  open_tmux_window "$name" "$root/$name"
}

cmd_rm() {
  local name="${1:?usage: wt rm <name> [--force]}"
  local force=false
  shift
  while [ $# -gt 0 ]; do
    case "$1" in
      --force) force=true ;;
      *) echo "error: unknown option $1" >&2; exit 1 ;;
    esac
    shift
  done

  local root
  root=$(project_root)

  if [ ! -d "$root/$name" ]; then
    echo "error: worktree '$root/$name' does not exist" >&2
    exit 1
  fi

  # Check for unpushed commits
  local upstream
  upstream=$(git -C "$root/$name" rev-parse --abbrev-ref '@{upstream}' 2>/dev/null || true)
  if [ -n "$upstream" ]; then
    local unpushed
    unpushed=$(git -C "$root/$name" log "$upstream..HEAD" --oneline 2>/dev/null || true)
    if [ -n "$unpushed" ]; then
      if [ "$force" = false ]; then
        echo "warning: branch '$name' has unpushed commits:" >&2
        echo "$unpushed" >&2
        echo "use --force to remove anyway" >&2
        exit 1
      fi
    fi
  fi

  echo "removing worktree $root/$name"
  if [ "$force" = true ]; then
    git worktree remove "$root/$name" --force
  else
    git worktree remove "$root/$name"
  fi

  # Delete local branch if it exists
  if git show-ref --verify --quiet "refs/heads/$name"; then
    echo "deleting branch $name"
    if [ "$force" = true ]; then
      git branch -D "$name"
    else
      git branch -d "$name"
    fi
  fi

  echo "done."
}

cmd_ls() {
  local detail=false
  if [ "${1:-}" = "--detail" ]; then
    detail=true
  fi

  if [ "$detail" = true ]; then
    ensure_gh_auth
    git worktree list --porcelain | while IFS= read -r line; do
      case "$line" in
        worktree\ *)
          wt_path="${line#worktree }"
          branch=""
          ;;
        branch\ *)
          branch="${line#branch refs/heads/}"
          ;;
        detached)
          branch="(detached)"
          ;;
        "")
          if [ -n "${branch:-}" ] && [ -n "${wt_path:-}" ]; then
            # Get last commit info
            local commit_info
            commit_info=$(git -C "$wt_path" log -1 --format="%h %s" 2>/dev/null || echo "n/a")
            # Get PR status
            local pr_status
            if [ "$branch" = "(detached)" ]; then
              pr_status="no PR"
            else
              pr_status=$(gh pr list --head "$branch" --json state,number --jq '.[0] | "#\(.number) \(.state)"' 2>/dev/null || echo "no PR")
            fi
            printf "%-30s %-40s %s  [%s]\n" "$branch" "$wt_path" "$commit_info" "$pr_status"
          fi
          branch=""
          wt_path=""
          ;;
      esac
    done
  else
    git worktree list --porcelain | while IFS= read -r line; do
      case "$line" in
        worktree\ *)
          wt_path="${line#worktree }"
          branch=""
          ;;
        branch\ *)
          branch="${line#branch refs/heads/}"
          ;;
        detached)
          branch="(detached)"
          ;;
        "")
          if [ -n "${branch:-}" ] && [ -n "${wt_path:-}" ]; then
            echo "$branch  $wt_path"
          fi
          branch=""
          wt_path=""
          ;;
      esac
    done
  fi
}

cmd_pr() {
  ensure_gh_auth
  local pr_number="${1:?usage: wt pr <number> [name]}"
  local name="${2:-}"

  # Fetch PR metadata
  local pr_branch
  pr_branch=$(gh pr view "$pr_number" --json headRefName --jq '.headRefName')

  if [ -z "$name" ]; then
    name="$pr_branch"
  fi

  local root
  root=$(project_root)

  if [ -d "$root/$name" ]; then
    echo "error: worktree '$root/$name' already exists" >&2
    exit 1
  fi

  echo "fetching origin..."
  git fetch origin

  echo "creating worktree at ../$name for PR #$pr_number (branch $pr_branch)"
  git worktree add "$root/$name" "origin/$pr_branch"
  git -C "$root/$name" checkout -B "$pr_branch" --track "origin/$pr_branch"
  echo "done."
  open_tmux_window "$name" "$root/$name"
}

cmd_clean() {
  ensure_gh_auth
  local root
  root=$(project_root)

  local current_wt
  current_wt=$(pwd -P)

  # Collect worktrees into arrays using process substitution
  local -a wt_names=()
  local -a wt_paths=()
  local -a to_remove=()

  while IFS= read -r line; do
    case "$line" in
      worktree\ *)
        _path="${line#worktree }"
        ;;
      branch\ *)
        _branch="${line#branch refs/heads/}"
        # Skip current worktree
        if [ "$_path" = "$current_wt" ]; then
          continue
        fi
        wt_names+=("$_branch")
        wt_paths+=("$_path")
        ;;
    esac
  done < <(git worktree list --porcelain)

  if [ ${#wt_names[@]} -eq 0 ]; then
    echo "nothing to clean."
    return
  fi

  echo "checking PR status for sibling worktrees..."
  for i in "${!wt_names[@]}"; do
    local branch="${wt_names[$i]}"
    local wt_path="${wt_paths[$i]}"
    local pr_state
    pr_state=$(gh pr list --head "$branch" --state merged --json number --jq '.[0].number' 2>/dev/null || true)
    if [ -n "$pr_state" ]; then
      echo "  $branch ($wt_path) - PR #$pr_state merged"
      to_remove+=("$i")
    fi
  done

  if [ ${#to_remove[@]} -eq 0 ]; then
    echo "nothing to clean."
    return
  fi

  echo ""
  read -rp "remove these ${#to_remove[@]} worktree(s)? [y/N] " confirm
  if [[ "$confirm" != [yY] ]]; then
    echo "cancelled."
    return
  fi

  for i in "${to_remove[@]}"; do
    local branch="${wt_names[$i]}"
    local wt_path="${wt_paths[$i]}"
    echo "removing $wt_path"
    git worktree remove "$wt_path" --force
    if git show-ref --verify --quiet "refs/heads/$branch"; then
      echo "deleting branch $branch"
      git branch -D "$branch"
    fi
  done

  echo "done."
}

ensure_git_repo

case "${1:-help}" in
  add)   shift; cmd_add "$@" ;;
  rm)    shift; cmd_rm "$@" ;;
  ls)    shift; cmd_ls "$@" ;;
  pr)    shift; cmd_pr "$@" ;;
  clean) shift; cmd_clean "$@" ;;
  help|-h|--help)  cmd_help ;;
  *)     echo "error: unknown command '$1' (try 'wt help')" >&2; exit 1 ;;
esac
